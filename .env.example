# --- Frontend (Vite) ---
# Base URL of the Express API. Leave empty for production on Vercel (same-origin /api
# routes); point at your local server for dev, e.g. http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787

# --- Backend (server/, loaded via dotenv from the repo root when running `npm run server`) ---
# Full Atlas SRV connection string from the cluster's "Connect" page in the Atlas dashboard.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/recruitix?retryWrites=true&w=majority
# Any random 32+ byte string (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace_with_a_random_secret
# Local dev only — Vercel provides its own port binding in production.
PORT=8787
